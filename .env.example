# URL base de tu instancia de Jira (sin barra final)
# Ejemplo: https://tu-empresa.atlassian.net
JIRA_BASE_URL=https://tu-empresa.atlassian.net

# Email de tu cuenta de Atlassian
JIRA_EMAIL=tu-email@empresa.com

# API Token generado en: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=tu_api_token_aqui

# Clave del proyecto en Jira (ej: PROJ, DEV, SUPPORT)
JIRA_PROJECT_KEY=PROJ
